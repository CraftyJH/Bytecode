# Supabase — get from your project dashboard (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Newer Supabase projects call this the "publishable key"; older ones call it "anon key"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key  # use this for older projects
# Service role key — server-only, never expose to the browser
# Used by the admin panel to manage users (Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Code execution (Judge0)
# Default: uses the free public Judge0 CE instance (no key needed, rate-limited)
# For the RapidAPI hosted instance, set both vars and update JUDGE0_URL:
#   JUDGE0_URL=https://judge0-ce.p.rapidapi.com
#   JUDGE0_API_KEY=your-rapidapi-key
JUDGE0_URL=https://ce.judge0.com

# Bytecode API (Spring Boot backend)
# Used by Next.js API routes to persist account-linked learning progress
BYTECODE_API_URL=http://localhost:8080

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PREMIUM_MONTHLY=price_...
STRIPE_PRICE_PREMIUM_YEARLY=price_...
# Optional: defaults to bytecode_premium_monthly_v1 / bytecode_premium_yearly_v1
STRIPE_LOOKUP_KEY_PREMIUM_MONTHLY=bytecode_premium_monthly_v1
STRIPE_LOOKUP_KEY_PREMIUM_YEARLY=bytecode_premium_yearly_v1

# Internal token shared by web + api for billing sync endpoints
BYTECODE_INTERNAL_BILLING_SYNC_TOKEN=replace-with-long-random-secret
